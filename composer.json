{
    "name": "wp-mcp/wp-mcp",
    "description": "WordPress MCP Server Plugin - Expose WordPress as an MCP server for AI agents",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "php-mcp/server": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "WpMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpMcp\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
